{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build:debug",
            "type": "cargo",
            "command": "build",
            "options": {
                "cwd": "${workspaceRoot}/src-tauri"
            }
        },
        {
            "label": "ui:dev",
            "type": "shell",
            "isBackground": true,
            "command": "npm",
            "args": ["run", "start"],
            "problemMatcher": {
                "pattern": { "regexp": "^ERROR" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Building\\.\\.\\.",
                    "endsPattern": "Local:.*localhost"
                }
            }
        },
        {
            "label": "dev",
            "dependsOn": ["build:debug", "ui:dev"],
            "group": { "kind": "build" }
        }
    ]
}
